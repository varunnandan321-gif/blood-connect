rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin Check Function
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'blood.connect123@gmail.com';
    }
    
    // USERS (Donor Identity Protection)
    match /Users/{userId} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      
      // NOTIFICATIONS Subcollection
      // Rule: Anyone logged in can create a notification (when broadcasting an emergency)
      // Rule: Only the specific Donor can read or delete their own notifications.
      // Rule: The original requester can also delete the notification to clean it up.
      match /Notifications/{notificationId} {
        allow create: if request.auth != null;
        allow read, update: if isAdmin() || (request.auth != null && request.auth.uid == userId);
        allow delete: if isAdmin() || (request.auth != null && request.auth.uid == userId) || request.auth != null; // Requester needs delete access
      }
    }

    // DELETION LOGS
    match /DeletionLogs/{logId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
    }

    // REQUESTS (Emergency Broadcasts)
    match /Requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin() || (request.auth != null && resource.data.requesterId == request.auth.uid);
    }

    // CHATS (Private 1-on-1 Messages)
    match /Chats/{chatId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid in resource.data.participants);
      allow create: if request.auth != null; 
      allow update, delete: if isAdmin() || (request.auth != null && request.auth.uid in resource.data.participants);
      
      // MESSAGES Subcollection
      match /Messages/{messageId} {
        allow read, write: if isAdmin() || (request.auth != null && request.auth.uid in get(/databases/$(database)/documents/Chats/$(chatId)).data.participants);
      }
    }

    // FACILITIES (Blood Banks & Hospitals)
    match /Facilities/{facilityId} {
        allow read: if request.auth != null;
        allow write: if isAdmin(); // Only admins can modify facilities directly securely
    }
  }
}
